{
  "name": "signalk-tailscale-server",
  "version": "0.1.0",
  "description": "Headless Tailscale engine for the signalk-tailscale plugin: userspace-networking tailscaled + serve, driven by the plugin over a loopback REST shim",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:all": "npm run lint && npm run build && npm run test",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"README.md\" && npm run lint:fix",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\" \"README.md\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.30",
    "better-sse": "^0.16.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "supertest": "^7.1.1",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "qs": ">=6.15.2"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dirkwa/signalk-tailscale-server.git"
  }
}
